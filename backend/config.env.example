# Configuration PostgreSQL
# Copiez ce fichier en config.env et remplissez avec vos vraies valeurs.
# NE COMMITEZ JAMAIS config.env (il contient des secrets).

# --- Lier la base locale à la base en ligne (Neon/Render) ---
# Si vous définissez DATABASE_URL avec l'URL de votre base en ligne, le backend
# utilisera cette base au lieu de localhost. Ainsi "base locale" = même données que en ligne.
# DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# --- Base locale (utilisée seulement si DATABASE_URL n'est pas défini) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enfants_adam_eve
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# Configuration JWT
# IMPORTANT: Changez cette clé secrète en production !
JWT_SECRET=your_secret_key_here_generate_a_random_string
JWT_EXPIRE=7d

# Configuration bcrypt
BCRYPT_ROUNDS=12

# Port du serveur
PORT=5002

# Environnement
NODE_ENV=development

# Configuration CORS
CORS_ORIGIN=http://localhost:5173

# Configuration des uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Mot de passe administrateur
# IMPORTANT: Changez ce mot de passe en production !
ADMIN_PASSWORD=your_admin_password_here
ADMIN_NUMERO_H=G0C0P0R0E0F0 0

# Envoyer la base locale vers Render (copie l'URL dans Render → PostgreSQL → Connection)
# RENDER_DATABASE_URL=postgresql://user:password@host/db?sslmode=require
